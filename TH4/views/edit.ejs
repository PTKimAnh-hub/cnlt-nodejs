<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Sửa bài viết</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<header>Blog chia sẻ</header>

<div class="container">

    <div class="post">
        <h2>Sửa bài viết</h2>

        <form action="/blogposts/update/<%= post._id %>" method="POST">

            <input 
                type="text" 
                name="title" 
                value="<%= post.title %>"
                style="   width: 90%;
                        padding: 12px;
                        margin-top: 8px;
                        margin-bottom: 20px;
                        border-radius: 6px;
                        border: 1px solid #ccc;"
            >

            <textarea 
                name="body" 
                rows="5"
                style="   width: 90%;
                        padding: 12px;
                        margin-top: 8px;
                        margin-bottom: 20px;
                        border-radius: 6px;
                        border: 1px solid #ccc;"
            ><%= post.body %></textarea>

            <button 
            style="margin-top:15px; background:#1877f2; color:white; padding:10px 20px; border:none; border-radius:6px; cursor:pointer;"
            type="submit">Cập nhật bài viết
            </button>

        </form>
    </div>

</div>

</body>
</html>
